# Node Environment
NODE_ENV=development

# Server Configuration
PORT=3000
HOST=localhost

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=smartquote
DB_USER=postgres
DB_PASSWORD=your_database_password_here

# Auth & Session Configuration
SESSION_SECRET=your_session_secret_here_at_least_32_characters_long
SESSION_EXPIRY_HOURS=168
BCRYPT_SALT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOGIN_RATE_LIMIT_WINDOW_MINUTES=15

# API
JWT_SECRET=your_session_secret_here_at_least_32_characters_long

# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# When running via Docker Compose, this is set automatically.
# Leave blank when running the API as a bare Node process without Docker --
# embedding-dependent features (ticket priority NLP signal, similarity search)
# will degrade gracefully to rule-based fallbacks.
EMBEDDING_SERVICE_URL=http://localhost:8001

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_setup_email_address_here
SMTP_PASSWORD=your_smtp_password_here

# Application URLs
VITE_APP_URL=http://localhost:3000
VITE_FRONTEND_URL=http://localhost:5173