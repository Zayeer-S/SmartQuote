{
  "name": "smartqoute",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:full": "concurrently \"npm run dev:client\" \"npm run dev:server\" \"npm run dev:ml\"",
    "dev:client": "vite",
    "dev:server": "tsx watch src/server/bootstrap/server.ts",
    "dev:ml": "concurrently \"npm run dev:ml:embedder\" \"npm run dev:ml:quote\"",
    "dev:ml:embedder": "cd models/embedder && uvicorn app:app --host 0.0.0.0 --port 8001 --reload",
    "dev:ml:quote": "cd models/handler && uvicorn handler:app --host 0.0.0.0 --port 8002 --reload",
    "build": "tsc -b && vite build",
    "build:server": "tsc --project tsconfig.server.json --noEmit",
    "build:client": "vite build",
    "build:ws": "tsc -p tsconfig.ws.json",
    "build:all": "npm run build:server && npm run build:client && npm run build:db && npm run build:ws",
    "build:db": "tsc --project tsconfig.migrations.json",
    "preview": "vite preview",
    "start": "tsx src/server/bootstrap/server.ts",
    "start:prod": "cross-env NODE_ENV=production tsx src/server/bootstrap/server.ts",
    "db:migrate": "tsx ./node_modules/knex/bin/cli.js migrate:latest --knexfile knexfile.ts",
    "db:migrate:make": "tsx ./node_modules/knex/bin/cli.js migrate:make --knexfile knexfile.ts",
    "db:migrate:rollback": "tsx ./node_modules/knex/bin/cli.js migrate:rollback --knexfile knexfile.ts",
    "db:migrate:rollback:all": "tsx ./node_modules/knex/bin/cli.js migrate:rollback --all --knexfile knexfile.ts",
    "db:seed": "tsx ./node_modules/knex/bin/cli.js seed:run --knexfile knexfile.ts",
    "db:seed:make": "tsx ./node_modules/knex/bin/cli.js seed:make --knexfile knexfile.ts",
    "db:reset": "npm run db:migrate:rollback:all && npm run db:migrate && npm run db:seed",
    "db:unlock": "node --import tsx/esm ./node_modules/knex/bin/cli.js migrate:unlock --knexfile knexfile.ts --env test",
    "infra:setup": "git pull && npm i && npm run build:all",
    "infra:deploy-all": "cd infra && npx cdk deploy SmartQuoteAppStack --require-approval never && aws lambda invoke --function-name smartquote-migrate --region eu-west-2 migrate.json && cat migrate.json && cd ..",
    "infra:seed-reset": "cd infra && aws lambda invoke --function-name smartquote-seed --region eu-west-2 seed.json && cat seed.json && cd ..",
    "test:unit:client": "vitest --config vitest.config.unit.client.ts",
    "test:unit:client:run": "vitest run --config vitest.config.unit.client.ts",
    "test:unit:client:coverage": "vitest run --config vitest.config.unit.client.ts --coverage",
    "test:unit:server": "vitest --config vitest.config.unit.server.ts",
    "test:unit:server:run": "vitest run --config vitest.config.unit.server.ts",
    "test:unit:server:coverage": "vitest run --config vitest.config.unit.server.ts --coverage",
    "test:unit": "npm run test:unit:client:run && npm run test:unit:server:run",
    "test:unit:coverage": "npm run test:unit:client:coverage && npm run test:unit:server:coverage",
    "test:integration": "cross-env NODE_ENV=test vitest --config vitest.config.integration.ts",
    "test:integration:run": "cross-env NODE_ENV=test vitest run --config vitest.config.integration.ts",
    "test:integration:coverage": "cross-env NODE_ENV=test vitest run --config vitest.config.integration.ts --coverage",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test tests/e2e/smoke",
    "test:e2e:flows": "playwright test tests/e2e/flows",
    "test:e2e:debug": "playwright test --debug",
    "test:all": "npm run test:unit:run && npm run test:integration:run && npm run test:e2e",
    "test:coverage": "npm run test:unit:coverage && npm run test:integration:coverage",
    "test:infra": "cd infra && npx jest test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\"",
    "type-check": "tsc --noEmit",
    "type-check:client": "tsc --project tsconfig.app.json --noEmit",
    "type-check:server": "tsc --project tsconfig.server.json --noEmit",
    "check": "npm run lint && npm run type-check && npm run format:check",
    "docker:dev": "docker-compose up",
    "docker:dev:build": "docker-compose up --build",
    "docker:dev:down": "docker-compose down",
    "docker:dev:clean": "docker-compose down -v",
    "docker:prod:build": "docker build -f Dockerfile.prod -t prototype:latest .",
    "docker:prod:run": "docker run -p 3000:3000 --env-file .env.local prototype:latest",
    "clean": "rm -rf dist node_modules/.vite",
    "clean:all": "rm -rf dist node_modules node_modules/.vite",
    "ci:test": "npm run lint && npm run type-check && npm run test:run && npm run test:e2e",
    "ci:build": "npm run build:all",
    "validate": "npm run check && npm run test:run",
    "prepare": "husky",
    "setup": "npm i && npm audit fix --force && cp .env.example .env.local && docker-compose up -d && db:reset",
    "setup:ml": "pip install -r models/embedder/requirements.txt && pip install -r models/handler/requirements.txt"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1015.0",
    "@aws-sdk/client-secrets-manager": "^3.994.0",
    "@aws-sdk/s3-request-presigner": "^3.1017.0",
    "axios": "1.13.5",
    "bcryptjs": "^3.0.3",
    "busboy": "^1.6.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "knex": "^3.1.0",
    "libphonenumber-js": "^1.12.36",
    "nodemailer": "^8.0.1",
    "pg": "^8.18.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-email": "^5.2.8",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.13.0",
    "recharts": "^3.7.0",
    "serverless-http": "^3.2.0",
    "smtp-server": "^3.18.1",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/busboy": "^1.5.4",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.10.1",
    "@types/nodemailer": "^7.0.9",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^6.0.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^3.0.5",
    "@vitest/ui": "^3.0.5",
    "concurrently": "^9.1.2",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jsdom": "^25.0.1",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^3.0.5"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
