{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.ws.tsbuildinfo",
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["node"],
    "skipLibCheck": true,

    /* Emit */
    "noEmit": false,
    "outDir": "dist-ws",
    "rootDir": "src",
    "declaration": false,
    "sourceMap": false,

    /* Interop */
    "esModuleInterop": true,
    "verbatimModuleSyntax": false,
    "moduleDetection": "force",

    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  },
  "include": ["src/server/**/*", "src/shared/**/*"]
}
